# Telegram
TELEGRAM_TOKEN=токен_от_@BotFather
ALLOWED_USER_ID=твой_telegram_id  # Получить: написать @userinfobot

# HH.ru
HH_PHONE=+79001234567

# Ollama
# Локально: http://localhost:11434
# Docker:   http://ollama:11434  (задаётся автоматически в docker-compose.yml)
OLLAMA_URL=http://localhost:11434
OLLAMA_MODEL=qwen2.5:7b   # Альтернативы: qwen2.5:3b (легче), qwen2.5:14b (лучше)

# Бот
# Локально: hh_bot.db / hh_session.json
# Docker:   data/hh_bot.db / data/hh_session.json (задаётся в docker-compose.yml)
DB_PATH=hh_bot.db
SESSION_FILE=hh_session.json
SCAN_INTERVAL_HOURS=2
MAX_VACANCIES_PER_SCAN=50
DEFAULT_SEARCH_QUERY=Python разработчик

# Веб-интерфейс
WEB_HOST=0.0.0.0
WEB_PORT=8080

# Docker: где хранить модель Ollama (~5 ГБ). Укажи диск с местом.
OLLAMA_DATA_DIR=D:/docker-data/ollama

# Матчинг
MIN_MATCH_THRESHOLD=0.65
HH_REGION=1
HH_SEARCH_PERIOD=1
USE_LLM_FOR_KEYWORDS=true

# Семантический матчинг (Ollama embeddings)
EMBED_MODEL=bge-m3
EMBED_SEM_THRESHOLD=0.62
MATCH_WEIGHT_EXACT=0.6
MATCH_WEIGHT_SEM=0.4

# Фильтр по опыту: пропускать вакансии, где требуемый стаж заметно выше стажа в резюме
EXPERIENCE_FILTER_ENABLED=true
EXPERIENCE_TOLERANCE_YEARS=0.5

# Сопроводительное письмо: ollama | claude
COVER_LETTER_BACKEND=ollama
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-4-20250514

# Telegram-каналы (Telethon user-session, не бот-токен)
# API_ID/API_HASH: https://my.telegram.org → API development tools
# Логин сессии: docker compose run --rm worker python tg_login.py
TG_SCAN_ENABLED=false
TELEGRAM_API_ID=
TELEGRAM_API_HASH=
TG_USER_SESSION=data/tg_user
TG_CHANNELS_FOLDER=Вакансии
TG_LOOKBACK_HOURS=24
TG_MAX_MESSAGES_PER_CHANNEL=30
